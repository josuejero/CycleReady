  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@types/node": "25.3.3",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.1.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.34",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.3.2",
    "vite": "^5.0.3"
  }
}
