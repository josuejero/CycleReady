{
  "name": "cycleready",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/sync-static.js && vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
